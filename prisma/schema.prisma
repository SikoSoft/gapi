// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-1.1.x"]
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Action {
  id         Int         @id @default(autoincrement())
  desc       String      @db.VarChar(255)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  occurredAt DateTime    @default(now())
  userId     String?     @db.Uuid
  tags       ActionTag[]
}

model BooleanPropertyValue {
  id    Int     @id @default(autoincrement())
  value Boolean

  propertyConfigDefaultValue PropertyConfigBooleanDefaultValue?
  entityPropertyValue        EntityBooleanProperty?
  listFilterPropertyValue    ListFilterBooleanProperty?
}

model DatePropertyValue {
  id    Int      @id @default(autoincrement())
  value DateTime @default(now())

  propertyConfigDefaultValue PropertyConfigDateDefaultValue?
  entityPropertyValue        EntityDateProperty?
  listFilterPropertyValue    ListFilterDateProperty?
}

model ImagePropertyValue {
  id      Int    @id @default(autoincrement())
  url     String
  altText String

  propertyConfigDefaultValue PropertyConfigImageDefaultValue?
  entityPropertyValue        EntityImageProperty?
  listFilterPropertyValue    ListFilterImageProperty?
}

model IntPropertyValue {
  id    Int @id @default(autoincrement())
  value Int

  propertyConfigDefaultValue PropertyConfigIntDefaultValue?
  entityPropertyValue        EntityIntProperty?
  listFilterPropertyValue    ListFilterIntProperty?
}

model LongTextPropertyValue {
  id    Int    @id @default(autoincrement())
  value String

  propertyConfigDefaultValue PropertyConfigLongTextDefaultValue?
  entityPropertyValue        EntityLongTextProperty?
  listFilterPropertyValue    ListFilterLongTextProperty?
}

model ShortTextPropertyValue {
  id    Int    @id @default(autoincrement())
  value String

  propertyConfigDefaultValue PropertyConfigShortTextDefaultValue?
  entityPropertyValue        EntityShortTextProperty?
  listFilterPropertyValue    ListFilterShortTextProperty?
}

model PropertyConfigBooleanDefaultValue {
  propertyValueId  Int @unique
  propertyConfigId Int @unique

  propertyConfig PropertyConfig       @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  booleanValue   BooleanPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model PropertyConfigDateDefaultValue {
  propertyValueId  Int @unique
  propertyConfigId Int @unique

  propertyConfig PropertyConfig    @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  dateValue      DatePropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model PropertyConfigImageDefaultValue {
  propertyValueId  Int @unique
  propertyConfigId Int @unique

  propertyConfig PropertyConfig     @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  imageValue     ImagePropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model PropertyConfigIntDefaultValue {
  propertyValueId  Int @unique
  propertyConfigId Int @unique

  propertyConfig PropertyConfig   @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  intValue       IntPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model PropertyConfigLongTextDefaultValue {
  propertyValueId  Int @unique
  propertyConfigId Int @unique

  propertyConfig PropertyConfig        @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  longTextValue  LongTextPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model PropertyConfigShortTextDefaultValue {
  propertyValueId  Int @unique
  propertyConfigId Int @unique

  propertyConfig PropertyConfig         @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  shortTextValue ShortTextPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model EntityBooleanProperty {
  id               Int @id @default(autoincrement())
  entityId         Int
  propertyConfigId Int
  propertyValueId  Int @unique
  order            Int @default(0)

  entity         Entity               @relation(fields: [entityId], references: [id], onDelete: Cascade)
  propertyValue  BooleanPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
  propertyConfig PropertyConfig       @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@index([entityId, order], map: "idx_entitybooleanprop_entityid_order")
}

model EntityDateProperty {
  id               Int @id @default(autoincrement())
  entityId         Int
  propertyConfigId Int
  propertyValueId  Int @unique
  order            Int @default(0)

  entity         Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)
  propertyValue  DatePropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
  propertyConfig PropertyConfig    @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@index([entityId, order], map: "idx_entitydateprop_entityid_order")
}

model EntityImageProperty {
  id               Int @id @default(autoincrement())
  entityId         Int
  propertyConfigId Int
  propertyValueId  Int @unique
  order            Int @default(0)

  entity         Entity             @relation(fields: [entityId], references: [id], onDelete: Cascade)
  propertyValue  ImagePropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
  propertyConfig PropertyConfig     @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@index([entityId, order], map: "idx_entityimageprop_entityid_order")
}

model EntityIntProperty {
  id               Int @id @default(autoincrement())
  entityId         Int
  propertyConfigId Int
  propertyValueId  Int @unique
  order            Int @default(0)

  entity         Entity           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  propertyValue  IntPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
  propertyConfig PropertyConfig   @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@index([entityId, order], map: "idx_entityintprop_entityid_order")
}

model EntityLongTextProperty {
  id               Int @id @default(autoincrement())
  entityId         Int
  propertyConfigId Int
  propertyValueId  Int @unique
  order            Int @default(0)

  entity         Entity                @relation(fields: [entityId], references: [id], onDelete: Cascade)
  propertyValue  LongTextPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
  propertyConfig PropertyConfig        @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@index([entityId, order], map: "idx_entitylongtextprop_entityid_order")
}

model EntityShortTextProperty {
  id               Int @id @default(autoincrement())
  entityId         Int
  propertyConfigId Int
  propertyValueId  Int @unique
  order            Int @default(0)

  entity         Entity                 @relation(fields: [entityId], references: [id], onDelete: Cascade)
  propertyValue  ShortTextPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
  propertyConfig PropertyConfig         @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@index([entityId, order], map: "idx_entityshorttextprop_entityid_order")
}

model Entity {
  id                  Int                       @id @default(autoincrement())
  entityConfigId      Int
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  userId              String?                   @db.Uuid
  tags                EntityTag[]
  booleanProperties   EntityBooleanProperty[]
  dateProperties      EntityDateProperty[]
  imageProperties     EntityImageProperty[]
  intProperties       EntityIntProperty[]
  longTextProperties  EntityLongTextProperty[]
  shortTextProperties EntityShortTextProperty[]

  entityConfig EntityConfig        @relation(fields: [entityConfigId], references: [id], onDelete: Cascade)
  accessPolicy EntityAccessPolicy?

  @@index([userId, createdAt], map: "idx_entity_userid_createdat")
}

model EntityPropertyConfigOrder {
  entityConfigId   Int
  propertyConfigId Int @unique
  order            Int @default(0)

  entityConfig   EntityConfig   @relation(fields: [entityConfigId], references: [id], onDelete: Cascade)
  propertyConfig PropertyConfig @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@unique([entityConfigId, propertyConfigId])
}

model OptionsShortTextOption {
  id               Int    @id @default(autoincrement())
  propertyConfigId Int
  value            String @db.VarChar(255)

  propertyConfig PropertyConfig @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@unique([propertyConfigId, value])
  @@index([propertyConfigId], map: "idx_optionstextoption_propertyconfigid")
}

model OptionsIntOption {
  id               Int @id @default(autoincrement())
  propertyConfigId Int
  value            Int

  propertyConfig PropertyConfig @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)

  @@unique([propertyConfigId, value])
  @@index([propertyConfigId], map: "idx_optionsintoption_propertyconfigid")
}

model PropertyConfig {
  id               Int                      @id @default(autoincrement())
  name             String                   @db.VarChar(128)
  dataType         String                   @db.VarChar(128)
  repeat           Int                      @default(0)
  allowed          Int                      @default(0)
  required         Int                      @default(0)
  prefix           String                   @db.VarChar(128)
  suffix           String                   @db.VarChar(128)
  hidden           Boolean                  @default(false)
  userId           String?                  @db.Uuid
  entityConfigId   Int                      @default(0)
  optionsOnly      Boolean                  @default(false)
  optionsShortText OptionsShortTextOption[]
  optionsInt       OptionsIntOption[]

  entityConfig EntityConfig @relation(fields: [entityConfigId], references: [id], onDelete: Cascade)

  defaultBooleanValue   PropertyConfigBooleanDefaultValue?
  defaultDateValue      PropertyConfigDateDefaultValue?
  defaultImageValue     PropertyConfigImageDefaultValue?
  defaultIntValue       PropertyConfigIntDefaultValue?
  defaultLongTextValue  PropertyConfigLongTextDefaultValue?
  defaultShortTextValue PropertyConfigShortTextDefaultValue?

  entityPropertyConfigOrder EntityPropertyConfigOrder?

  entityBooleanProperties   EntityBooleanProperty[]
  entityImageProperties     EntityImageProperty[]
  entityDateProperties      EntityDateProperty[]
  entityIntProperties       EntityIntProperty[]
  entityLongTextProperties  EntityLongTextProperty[]
  entityShortTextProperties EntityShortTextProperty[]

  listFilterBooleanProperties   ListFilterBooleanProperty[]
  listFilterDateProperties      ListFilterDateProperty[]
  listFilterImageProperties     ListFilterImageProperty[]
  listFilterIntProperties       ListFilterIntProperty[]
  listFilterLongTextProperties  ListFilterLongTextProperty[]
  listFilterShortTextProperties ListFilterShortTextProperty[]

  @@unique([entityConfigId, id])
}

model EntityConfig {
  id                    Int              @id @default(autoincrement())
  name                  String           @db.VarChar(128)
  allowPropertyOrdering Boolean          @default(false)
  description           String?          @db.VarChar(255)
  properties            PropertyConfig[]
  userId                String?          @db.Uuid
  revisionOf            Int?
  aiEnabled             Boolean          @default(false)
  aiIdentifyPrompt      String?          @db.VarChar(255)
  public                Boolean          @default(false)

  entityPropertyConfigOrders EntityPropertyConfigOrder[]
  entities                   Entity[]
  revision                   EntityConfig?               @relation("EntityConfigRevisions", fields: [revisionOf], references: [id])
  revisions                  EntityConfig[]              @relation("EntityConfigRevisions")
  ListFilterType             ListFilterType[]
  accessPolicy               EntityConfigAccessPolicy?

  @@unique([id, name])
}

model ActionTag {
  actionId Int    @default(0)
  label    String @db.VarChar(128)
  action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [label], references: [label], onDelete: Cascade)

  @@id([actionId, label])
}

model EntityTag {
  id       Int    @id @default(autoincrement())
  entityId Int    @default(0)
  label    String @db.VarChar(128)
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [label], references: [label], onDelete: Cascade)

  @@index([entityId, label], map: "idx_entitytag_entityid_label")
  @@index([label], map: "idx_entitytag_label")
}

model Tag {
  label     String      @unique @db.VarChar(128)
  actionTag ActionTag[]
  entityTag EntityTag[]
}

model Leaderboard {
  id       Int      @id @default(autoincrement())
  name     String   @db.VarChar(64)
  score    Int      @default(0)
  duration Int      @default(0)
  time     DateTime @updatedAt
  ip       String   @db.VarChar(64)
}

model ListConfig {
  id                   String                  @id @db.Uuid
  name                 String                  @db.VarChar(128)
  userId               String?                 @db.Uuid
  sort                 ListSort?
  filter               ListFilter?
  setting              Setting?
  themes               ListConfigTheme[]
  workspaceListConfigs WorkspaceListConfig[]
  accessPolicy         ListConfigAccessPolicy?
}

model ListConfigTheme {
  listConfigId String     @db.Uuid
  theme        String     @db.VarChar(64)
  order        Int        @default(0)
  listConfig   ListConfig @relation(fields: [listConfigId], references: [id], onDelete: Cascade)

  @@unique([listConfigId, theme])
}

model ListSort {
  listConfigId String     @unique @db.Uuid
  property     String?    @db.VarChar(64)
  propertyId   Int?       @default(0)
  dataType     String?    @db.VarChar(64)
  direction    String     @db.VarChar(64)
  listConfig   ListConfig @relation(fields: [listConfigId], references: [id], onDelete: Cascade)
}

model ListFilterTime {
  listConfigId String     @unique @db.Uuid
  type         String     @db.VarChar(64)
  date1        String?
  date2        String?
  listFilter   ListFilter @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
}

model ListFilterText {
  listConfigId String     @id @db.Uuid
  type         String     @db.VarChar(64)
  subStr       String     @db.VarChar(255)
  listFilter   ListFilter @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
}

model ListFilterTag {
  listConfigId String     @db.Uuid
  type         String     @db.VarChar(64)
  tag          String     @db.VarChar(255)
  listFilter   ListFilter @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)

  @@unique([listConfigId, tag, type])
}

model ListFilterType {
  entityConfigId Int
  listConfigId   String @db.Uuid

  entityConfig EntityConfig @relation(fields: [entityConfigId], references: [id], onDelete: Cascade)
  listFilter   ListFilter   @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)

  @@id([entityConfigId, listConfigId])
}

model ListFilter {
  listConfigId      String           @unique @db.Uuid
  includeUntagged   Boolean          @default(false)
  includeAll        Boolean          @default(false)
  includeAllTagging Boolean          @default(false)
  includeTypes      ListFilterType[]
  time              ListFilterTime?
  text              ListFilterText[]
  tagging           ListFilterTag[]
  listConfig        ListConfig       @relation(fields: [listConfigId], references: [id], onDelete: Cascade)

  booleanProperties   ListFilterBooleanProperty[]
  dateProperties      ListFilterDateProperty[]
  imageProperties     ListFilterImageProperty[]
  intProperties       ListFilterIntProperty[]
  longTextProperties  ListFilterLongTextProperty[]
  shortTextProperties ListFilterShortTextProperty[]
}

model ListFilterBooleanProperty {
  id               Int    @id @default(autoincrement())
  listConfigId     String @db.Uuid
  propertyConfigId Int
  propertyValueId  Int    @unique

  listFilter     ListFilter           @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
  propertyConfig PropertyConfig       @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  propertyValue  BooleanPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model ListFilterDateProperty {
  id               Int    @id @default(autoincrement())
  listConfigId     String @db.Uuid
  propertyConfigId Int
  propertyValueId  Int    @unique

  listFilter     ListFilter        @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
  propertyConfig PropertyConfig    @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  propertyValue  DatePropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model ListFilterImageProperty {
  id               Int    @id @default(autoincrement())
  listConfigId     String @db.Uuid
  propertyConfigId Int
  propertyValueId  Int    @unique

  listFilter     ListFilter         @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
  propertyConfig PropertyConfig     @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  propertyValue  ImagePropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model ListFilterIntProperty {
  id               Int    @id @default(autoincrement())
  listConfigId     String @db.Uuid
  propertyConfigId Int
  propertyValueId  Int    @unique

  listFilter     ListFilter       @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
  propertyConfig PropertyConfig   @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  propertyValue  IntPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model ListFilterLongTextProperty {
  id               Int    @id @default(autoincrement())
  listConfigId     String @db.Uuid
  propertyConfigId Int
  propertyValueId  Int    @unique

  listFilter     ListFilter            @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
  propertyConfig PropertyConfig        @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  propertyValue  LongTextPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model ListFilterShortTextProperty {
  id               Int    @id @default(autoincrement())
  listConfigId     String @db.Uuid
  propertyConfigId Int
  propertyValueId  Int    @unique

  listFilter     ListFilter             @relation(fields: [listConfigId], references: [listConfigId], onDelete: Cascade)
  propertyConfig PropertyConfig         @relation(fields: [propertyConfigId], references: [id], onDelete: Cascade)
  propertyValue  ShortTextPropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)
}

model User {
  id                  String                  @id @db.Uuid
  username            String                  @unique @db.VarChar(64)
  firstName           String                  @db.VarChar(64)
  lastName            String                  @db.VarChar(64)
  password            String                  @db.VarChar(255)
  roles               UserRole[]
  sessions            Session[]
  googleAccount       UserGoogleAccount[]
  accessPolicyGroups  AccessPolicyGroupUser[]
  accessPolicyParties AccessPolicyParty[]
}

model UserRole {
  userId  String   @db.Uuid
  role    String   @db.VarChar(128)
  addedAt DateTime @updatedAt
  user    User     @relation(fields: [userId], references: [id])

  @@id(name: "roleId", fields: [userId, role])
}

model UserGoogleAccount {
  userId       String   @db.Uuid
  googleId     String   @db.VarChar(255)
  email        String   @db.VarChar(255)
  refreshToken String
  addedAt      DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique(name: "googleAccountId", fields: [userId, googleId])
}

model Session {
  userId    String   @db.Uuid
  authToken String   @id @db.VarChar(128)
  createdAt DateTime @default(now())
  expiresAt DateTime @default(now())
  active    Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginAttempt {
  id          Int      @id @default(autoincrement())
  userId      String?  @db.Uuid
  attemptedAt DateTime @updatedAt
  ip          String   @db.VarChar(128)
}

model BooleanSetting {
  settingId String  @db.Uuid
  name      String  @db.VarChar(128)
  value     Boolean
  setting   Setting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique(name: "booleanSettingId", fields: [settingId, name])
}

model NumberSetting {
  settingId String  @db.Uuid
  name      String  @db.VarChar(128)
  value     Int
  setting   Setting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique(name: "numberSettingId", fields: [settingId, name])
}

model TextSetting {
  settingId String  @db.Uuid
  name      String  @db.VarChar(128)
  value     String  @db.VarChar(255)
  setting   Setting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique(name: "textSettingId", fields: [settingId, name])
}

model Setting {
  id              String           @unique @db.Uuid
  listConfigId    String           @id @db.Uuid
  booleanSettings BooleanSetting[]
  numberSettings  NumberSetting[]
  textSettings    TextSetting[]
  listConfig      ListConfig       @relation(fields: [listConfigId], references: [id], onDelete: Cascade)
}

model Workspace {
  id                   String                @id @db.Uuid
  name                 String                @db.VarChar(128)
  userId               String                @db.Uuid
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  workspaceListConfigs WorkspaceListConfig[]
}

model WorkspaceListConfig {
  workspaceId  String     @db.Uuid
  listConfigId String     @db.Uuid
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  listConfig   ListConfig @relation(fields: [listConfigId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, listConfigId])
}

model AccessPolicy {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(128)
  description String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parties                  AccessPolicyParty[]
  entityViewPolicies       EntityAccessPolicy[]       @relation("EntityViewAccessPolicy")
  entityEditPolicies       EntityAccessPolicy[]       @relation("EntityEditAccessPolicy")
  listConfigViewPolicies   ListConfigAccessPolicy[]   @relation("ListConfigViewAccessPolicy")
  listConfigEditPolicies   ListConfigAccessPolicy[]   @relation("ListConfigEditAccessPolicy")
  entityConfigViewPolicies EntityConfigAccessPolicy[] @relation("EntityConfigViewAccessPolicy")
  entityConfigEditPolicies EntityConfigAccessPolicy[] @relation("EntityConfigEditAccessPolicy")
}

model EntityAccessPolicy {
  entityId           Int  @unique
  viewAccessPolicyId Int?
  editAccessPolicyId Int?

  entity           Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  viewAccessPolicy AccessPolicy? @relation("EntityViewAccessPolicy", fields: [viewAccessPolicyId], references: [id], onDelete: Cascade)
  editAccessPolicy AccessPolicy? @relation("EntityEditAccessPolicy", fields: [editAccessPolicyId], references: [id], onDelete: Cascade)
}

model ListConfigAccessPolicy {
  listConfigId       String @unique @db.Uuid
  viewAccessPolicyId Int?
  editAccessPolicyId Int?

  listConfig       ListConfig    @relation(fields: [listConfigId], references: [id], onDelete: Cascade)
  viewAccessPolicy AccessPolicy? @relation("ListConfigViewAccessPolicy", fields: [viewAccessPolicyId], references: [id], onDelete: Cascade)
  editAccessPolicy AccessPolicy? @relation("ListConfigEditAccessPolicy", fields: [editAccessPolicyId], references: [id], onDelete: Cascade)
}

model EntityConfigAccessPolicy {
  entityConfigId     Int  @unique
  viewAccessPolicyId Int?
  editAccessPolicyId Int?

  entityConfig     EntityConfig  @relation(fields: [entityConfigId], references: [id], onDelete: Cascade)
  viewAccessPolicy AccessPolicy? @relation("EntityConfigViewAccessPolicy", fields: [viewAccessPolicyId], references: [id], onDelete: Cascade)
  editAccessPolicy AccessPolicy? @relation("EntityConfigEditAccessPolicy", fields: [editAccessPolicyId], references: [id], onDelete: Cascade)
}

model AccessPolicyParty {
  id             Int     @id @default(autoincrement())
  accessPolicyId Int
  type           String  @db.VarChar(16)
  userId         String? @db.Uuid
  groupId        Int?

  accessPolicy AccessPolicy       @relation(fields: [accessPolicyId], references: [id], onDelete: Cascade)
  user         User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        AccessPolicyGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model AccessPolicyGroup {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(128)
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   AccessPolicyGroupUser[]
  parties AccessPolicyParty[]
}

model AccessPolicyGroupUser {
  groupId Int
  userId  String @db.Uuid

  group AccessPolicyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model MapLocation {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(128)
  latitude         Float
  longitude        Float
  weatherForecasts WeatherForecast[]
}

/**
 * "air_temperature": 9.7,
 * "wind_from_direction": 304,
 * "wind_speed": 8.6,
 * "wind_speed_of_gust": 13.5,
 * "relative_humidity": 64,
 */

model WeatherForecast {
  id            Int      @id @default(autoincrement())
  locationId    Int
  snapshotTime  DateTime @default(now())
  forecastTime  DateTime
  temperature   Float
  precipitation Float
  windDirection Float
  windSpeed     Float
  windGust      Float
  humidity      Float

  location MapLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
}
